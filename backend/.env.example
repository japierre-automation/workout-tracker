# Postgres connection string (Railway provides this automatically when you add a
# Postgres plugin and reference it from the API service).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# HTTP server.
PORT=3000
HOST=0.0.0.0

# Dormant API-key gate. Leave disabled for the private-network MVP. To turn on:
#   API_KEY_ENABLED=true
#   API_KEY=<a long random string>
API_KEY_ENABLED=false
API_KEY=
